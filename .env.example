# ==============================================================================
# CHOZI.RU PRODUCTION ENVIRONMENT VARIABLES TEMPLATE
# Copy this file to '.env' on your VPS and fill in the values before deploying!
# ==============================================================================

# Database credentials
POSTGRES_USER=chozi_admin
POSTGRES_PASSWORD=replace_this_with_a_long_secure_random_password_123!
POSTGRES_DB=chozi_prod_db

# JSON Web Token Secret (used for signing and verifying user session tokens)
# Generate a secure random string (e.g., using 'openssl rand -base64 32')
JWT_SECRET=replace_this_with_a_very_long_secure_jwt_secret_token_key_here_987654321

# YooKassa acquiring parameters
YOOKASSA_SHOP_ID=1374499
YOOKASSA_SECRET_KEY=your_yookassa_secret_key_here

